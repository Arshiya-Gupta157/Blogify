<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head') %>
        <title>Blog</title>
</head>

<body>
    <%- include('./partials/nav') %>
        <div class="container mt-4">
            <h1>
                <%= blog.title %>
            </h1>
            <img src="<%= blog.coverImgURL %>" alt="coverImage" width="700vw">
            <pre
                class="mt-4"><%= blog.body%></p>
        </div>
        <div class="container mt-4">
            <img src="<%= blog.createdBy.profileImageUrl %>" alt="profilePic" width="30vw"> <%= blog.createdBy.fullName %>
        </div>
        <div class="container mt-3">
            <h1>Comments (<%= comments.length %>)</h1>
            <% if (locals.user) { %>
                <form action="/blog/comment/<%= blog._id %>" method="post">
                    <div class="mb-3 mt-4">
                        <input type="text" class="form-control" name="content" placeholder="Enter your comment...">
                    </div>
                    <button type="submit" class="btn btn-primary">Add</button>
                </form>
            <% } %>
        </div>
        <div class="container mt-3">
            <% comments.forEach(comment => { %>
                <div>
                    <img src="<%= comment.createdBy.profileImageUrl %>" alt="profilePic" width="30vw"> <%= comment.createdBy.fullName %>: <pre><%= comment.content %></pre>
                </div>
            <% }) %>
        </div>
        
    <%- include('./partials/script') %>
</body>

</html>